# SimpleBook SaaS Environment Configuration Example
# Copy this file to .env.local and fill in your actual Supabase credentials
# NOTE: .env.local is NOT committed to Git for security reasons

# Supabase Configuration
# Get these values from https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anonymous-api-key-here

# Optional: Service Role Key (for backend only, never expose in frontend)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Feature Flags
VITE_ENABLE_DEMO_MODE=false
VITE_API_TIMEOUT=5000
